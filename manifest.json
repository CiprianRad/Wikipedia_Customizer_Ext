{
  "manifest_version": 3,
  "name": "Wikipedia UI Customizer",
  "version": "1.0",
  "description": "Customize your Wikipedia reading experience by hiding distractions.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "*://*.wikipedia.org/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.wikipedia.org/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
